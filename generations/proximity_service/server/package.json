{
  "name": "proximity-service-server",
  "version": "1.0.0",
  "description": "Backend server for Proximity Service with semantic search",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "node -e \"import('pg').then(({default:pg})=>{const client=new pg.Client('postgres://postgres:postgrespw@localhost:55000/postgres');client.connect().then(()=>client.query(require('fs').readFileSync('../data/migration.sql','utf8'))).then(()=>{console.log('Migration complete');client.end();}).catch(e=>{console.error(e);client.end();process.exit(1);});})\""
  },
  "keywords": [
    "proximity",
    "search",
    "postgres",
    "semantic",
    "voyageai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "voyageai": "^0.2.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3",
    "vitest": "^1.0.4"
  }
}
