# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgres://postgres:postgrespw@localhost:55000/postgres

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Voyage AI Configuration (model: voyage-4-lite)
# Provide the key inline OR via a file path (inline takes precedence).
VOYAGE_API_KEY=your-voyage-api-key
VOYAGE_API_KEY_PATH=/tmp/api-key

# OneMap API Configuration (https://www.onemap.gov.sg/apidocs/)
# Used to geocode Singapore postal codes to latitude/longitude
ONEMAP_API_TOKEN=your-onemap-api-token
